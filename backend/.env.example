# ====================
# 应用配置
# ====================
APP_NAME="AI学习规划师"
DEBUG=True
LOG_LEVEL=DEBUG

# ====================
# 数据库
# ====================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_study
# 开发环境使用 SQLite
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ====================
# Redis
# ====================
REDIS_URL=redis://localhost:6379/0

# ====================
# JWT 密钥（生产环境请使用强随机密钥）
# ====================
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ====================
# 阿里云 DashScope（AI）
# ====================
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

# ====================
# 阿里云 OSS（文件存储）
# ====================
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET=ai-study-planner
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# ====================
# 阿里云短信（验证码）
# ====================
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=AI学习规划师
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# ====================
# 会员 Token 配额
# ====================
MONTHLY_TOKEN_QUOTA=100000
YEARLY_TOKEN_QUOTA=1000000
